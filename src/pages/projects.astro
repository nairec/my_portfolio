---
import Layout from "../layouts/Layout.astro";
import ProjectsTitle from "../components/ProjectsTitle.astro";
import ProjectTag from "../components/ProjectTag.astro";
import projectsData from "../projectsList.json";
import type { Project } from "../types/types";

const projects = [...(projectsData as Project[])].sort(
    (a, b) => b.year - a.year,
);

const widthScales: Record<number, string> = {
    1: "",
    2: "md:col-span-2",
    3: "md:col-span-3",
};

const heightScales: Record<number, string> = {
    1: "",
    2: "md:row-span-2",
    3: "md:row-span-3",
};
---

<Layout>
    <div transition:animate="fade">
        <ProjectsTitle />
        <div
            id="projects-grid"
            class="grid grid-cols-1 md:grid-cols-3 py-8 px-4 md:py-12 md:px-10 grid-flow-dense max-w-6xl mx-auto gap-0"
        >
            {
                projects.map((project) => (
                    <div
                        class:list={[
                            "project-tag-wrapper p-3 transition-opacity duration-base",
                            widthScales[project.width],
                            heightScales[project.height],
                        ]}
                        data-type={project.type}
                    >
                        <ProjectTag
                            name={project.name}
                            desc={project.description}
                            link={project.link}
                            imgPath={project.imgPath}
                            stack={project.stack}
                            year={project.year}
                            type={project.type}
                        />
                    </div>
                ))
            }
        </div>
    </div>
</Layout>
<script>
    import autoAnimate from "@formkit/auto-animate";
    import { mode } from "../projects.js";

    document.addEventListener("astro:page-load", () => {
        const grid = document.getElementById("projects-grid");
        if (grid) autoAnimate(grid, { duration: 250 });

        function applyFilter(value: string) {
            const wrappers = document.querySelectorAll(".project-tag-wrapper");
            wrappers.forEach((wrapper) => {
                const el = wrapper as HTMLElement;
                const projectType = el.getAttribute("data-type");
                if (projectType === value) {
                    el.classList.remove("hidden");
                } else {
                    el.classList.add("hidden");
                }
            });
        }

        mode.subscribe(applyFilter);
        applyFilter(mode.get());
    });
</script>
