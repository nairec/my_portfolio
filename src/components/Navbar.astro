---
const { pathname } = Astro.url;

const navItems = [
    { name: "Home", href: "/" },
    { name: "Projects", href: "/projects" },
    { name: "Blog", href: "/blog" },
];

const isActive = (href: string) => {
    const currentPath = pathname.replace(/\/$/, "");
    const targetPath = href.replace(/\/$/, "");
    return currentPath === targetPath;
};
---

<header>
    <nav
        class="flex flex-row gap-5 md:pr-10 items-center font-mono justify-end text-white p-5 w-full"
        aria-label="Main navigation"
    >
        {
            navItems.map((item, i) => (
                <a
                    href={item.href}
                    class:list={[
                        "interactive-base focus-ring pb-0.5",
                        isActive(item.href)
                            ? "text-cyan-300 border-b border-cyan-400/60"
                            : "text-white border-b border-transparent hover:text-cyan-300",
                    ]}
                >
                    <span class="text-accent">
                        {String(i + 1).padStart(2, "0")}.{" "}
                    </span>
                    {item.name}
                </a>
            ))
        }
    </nav>
</header>
