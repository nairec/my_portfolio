---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import eyeIcon from "../assets/SVGs/eye-icon.svg?raw";

export interface Props {
    name: string;
    desc: string;
    link: string;
    imgPath: string;
    stack: string[];
    year: number;
    type: "serious" | "fun";
}

const { name, desc, link, imgPath, stack, year, type } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/projectImages/*.{jpg,png,jpeg}",
    { eager: true },
);
if (!images[imgPath])
    throw new Error(
        `"${imgPath}" does not exist in glob: "/src/assets/projectImages/*.{jpeg,jpg,png}"`,
    );
---

<a
    href={link}
    target="_blank"
    rel="noopener noreferrer"
    class="project-card group flex flex-col gap-5 p-5 border-2 border-gray-600 backdrop-blur-lg
        w-full h-full interactive-base
        hover:border-cyan-400/40 hover:shadow-[0_0_24px_-8px_rgba(65,211,255,0.15)]
        focus-ring rounded-sm"
    data-project-type={type}
>
    <div class="flex flex-row items-center justify-between gap-3">
        <span
            class="text-xl font-semibold text-accent w-fit relative project-card-title"
        >
            {name}
        </span>
        <div class="flex items-center gap-2 shrink-0">
            <span class="text-xs font-mono text-gray-500 translate-y-[3px]">{year}</span>
            <span
                class="project-card-eye"
                aria-hidden="true"
                set:html={eyeIcon}
            />
        </div>
    </div>

    <div
        class="aspect-video overflow-hidden rounded-sm ring-2 ring-gray-700 shadow-[0_8px_10px_-4px_rgba(0,0,0,0.8)]"
    >
        <Image
            src={images[imgPath].default}
            alt={name}
            class="w-full h-full object-cover object-top select-none transition-transform duration-500 group-hover:scale-[1.02]"
        />
    </div>

    <p class="text-gray-200 text-sm leading-relaxed line-clamp-3">{desc}</p>

    <div class="flex flex-row gap-2 flex-wrap mt-auto">
        {
            stack.map((tag) => (
                <span class="px-2 py-0.5 text-xs font-mono text-cyan-300/90 border border-cyan-600/25 rounded-sm">
                    {type === "fun" ? `[${tag}]` : tag}
                </span>
            ))
        }
    </div>
</a>

<style>
    .project-card:hover {
        transform: scale(1.01);
    }

    .project-card-title {
        transition:
            color var(--duration-base) var(--ease-out-smooth),
            transform var(--duration-base) var(--ease-out-smooth);
    }

    .project-card:hover .project-card-title {
        color: var(--color-accent-hover);
        transform: translateX(12px);
    }

    .project-card-title::before {
        content: ">";
        position: absolute;
        left: 0;
        opacity: 0;
        transition:
            opacity var(--duration-fast) var(--ease-out-smooth),
            transform var(--duration-base) var(--ease-out-smooth);
    }

    .project-card:hover .project-card-title::before {
        opacity: 1;
        transform: translateX(-12px);
    }

    .project-card-eye {
        display: inline-flex;
        width: 1rem;
        height: 1rem;
        color: var(--color-accent);
        opacity: 0;
        transform: scale(0.85);
        filter: drop-shadow(0 0 0 transparent);
        transition:
            opacity var(--duration-base) var(--ease-out-smooth),
            color var(--duration-base) var(--ease-out-smooth),
            transform var(--duration-base) var(--ease-out-smooth),
            filter var(--duration-base) var(--ease-out-smooth);
    }

    .project-card-eye :global(svg) {
        width: 100%;
        height: 100%;
    }

    .project-card:hover .project-card-eye {
        opacity: 1;
        transform: scale(1);
        color: var(--color-accent-hover);
        filter: drop-shadow(0 0 6px color-mix(in srgb, var(--color-accent) 45%, transparent));
    }

    @media (prefers-reduced-motion: reduce) {
        .project-card:hover {
            transform: none;
        }

        .project-card:hover .project-card-title {
            transform: none;
        }
    }
</style>
